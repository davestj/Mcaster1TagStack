# ── Build outputs ──────────────────────────────────────────────────────────
build/
build-*/
out/
cmake-build-*/
*.app/
*.dmg
*.pkg

# ── Object / binary intermediates ──────────────────────────────────────────
*.o
*.obj
*.so
*.dylib
*.dll
*.exe
*.lib
*.a
*.pdb
*.idb

# ── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
.vs/
*.swp
*.swo
.DS_Store
.cache/
.claude/

# ── Real configs — NEVER commit. .example files are the committed templates.
# Mirrors the pattern used across Mcaster1: <name>.yaml gitignored,
# <name>.example.yaml committed.
tagstackd.yaml
tagstack.yaml
ollama.yaml
config.php
secrets.yaml
*.local.yaml
*.local.php
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────
logs/
*.log

# ── Generated artifacts ───────────────────────────────────────────────────
node_modules/
__pycache__/
*.pyc
.pytest_cache/

# ── Allow .example.* through (they ARE the committed templates) ───────────
!*.example.yaml
!*.example.yml
!*.example.php
!*.example.json
!*.example.env

# ── Reference-only artifacts (MFC legacy port reference, never goes here) ──
__REFERENCE_ONLY__.md
*.vcxproj
*.vcxproj.filters
*.sln
*.rc

# ── Ruby / Bundler — Capistrano deploy tooling ─────────────────────────────
vendor/bundle/
.bundle/

# ── Autotools generated (desktop/) — keep configure.ac + Makefile.am only ──
# Anything autoreconf, configure, or make produces is regenerable.
desktop/autom4te.cache/
desktop/aclocal.m4
desktop/configure
desktop/configure~
desktop/build-aux/
desktop/Makefile
desktop/Makefile.in
desktop/config.status
desktop/config.log
desktop/src/Makefile
desktop/src/Makefile.in
desktop/src/.deps/
desktop/src/moc_*.cpp
desktop/src/tagstack-desktop
desktop/m4/*.m4
!desktop/m4/.gitkeep
